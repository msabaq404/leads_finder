# Optional Gemini configuration
# .env values override existing shell vars by default (set to 0 to disable)
LEADS_DOTENV_OVERRIDE=1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_DEBUG=0
GEMINI_BATCH_SIZE=10
GEMINI_REQUESTS_PER_MINUTE=5
GEMINI_DAILY_REQUEST_LIMIT=20

# Optional source API credentials (future auth wiring)
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_BEARER_TOKEN=

# Source enablement
LEADS_ENABLE_REDDIT=1
LEADS_ENABLE_GITHUB_ISSUES=1
LEADS_ENABLE_HACKER_NEWS=1
LEADS_ENABLE_DEV_TO=0

# Local persistence
LEADS_DB_PATH=leads_finder.db

# Storage backend: sqlite or azure_sql
LEADS_DB_BACKEND=sqlite

# Azure SQL (Entra-only): provide one full connection string.
# Example:
# Driver={ODBC Driver 18 for SQL Server};Server=tcp:<server>.database.windows.net,1433;Database=<db>;Encrypt=yes;TrustServerCertificate=no;Authentication=ActiveDirectoryMsi;
AZURE_SQL_CONNECTION_STRING=

# Scheduler
LEADS_RUN_INTERVAL_MINUTES=60
LEADS_HOURS_BACK=168

# Filtering
LEADS_MIN_CONFIDENCE=0.35
LEADS_ENRICH_TOP_FRACTION=1.0
